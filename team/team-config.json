{
  "version": "1.0.0",
  "mode": "minimal",
  "phases": [
    "planning",
    "exec",
    "verify",
    "completed"
  ],
  "agents": {
    "planner": {
      "description": "Extracts requirements, defines scope, writes plan.md",
      "model": "kimi-k2.5:cloud",
      "timeout": 300
    },
    "executor": {
      "description": "Implements the plan, writes code to exec/",
      "model": "kimi-k2.5:cloud",
      "timeout": 600
    },
    "verifier": {
      "description": "Validates execution against plan, writes verify/report.json",
      "model": "kimi-k2.5:cloud",
      "timeout": 300
    }
  },
  "settings": {
    "maxRetries": 3,
    "autoArchive": true,
    "notifyOnComplete": true,
    "notificationBot": "Notification_bot",
    "notificationPrefix": "TUI"
  },
  "paths": {
    "base": "~/.openclaw/workspace/team",
    "active": "~/.openclaw/workspace/team/active",
    "archive": "~/.openclaw/workspace/team/archive",
    "templates": "~/.openclaw/workspace/team/templates"
  }
}
